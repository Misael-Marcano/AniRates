# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:5000
# URL pública del API (HTTPS en prod). List-Unsubscribe RFC 8058 usa BACKEND_URL + /auth/email-unsubscribe/one-click
BACKEND_URL=http://localhost:5001

# ─── Database (SQL Server) ──────────────────────────────────────────────────
DB_HOST=localhost
# SQL Server local suele usar 1433. El docker-compose en la raíz del repo mapea el contenedor como 1435:1433 → desde el host pon DB_PORT=1435.
DB_PORT=1433
DB_USER=sa
DB_PASS=TuPasswordAqui
DB_NAME=AniRate

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=anirate-super-secret-key-min-16-chars

# ─── Email (Resend recomendado, fallback SMTP) ──────────────────────────────
MAIL_FROM=AniRate <noreply@anirate.app>
RESEND_API_KEY=
# Opcional: Bearer para POST /auth/mail-webhooks/resend (eventos Resend: bounce permanente / complaint → suprime envíos)
RESEND_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ─── Digest semanal (email) ─────────────────────────────────────────────────
# Cron 5 campos: minuto hora día-mes mes día-semana (0 = domingo). Default domingo 09:00.
# WEEKLY_DIGEST_CRON=0 9 * * 0
# DISABLE_WEEKLY_DIGEST_CRON=true

# ─── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ─── Cache ──────────────────────────────────────────────────────────────────
REDIS_URL=

# ─── Proxy Jikan (GET /jikan/v4/* → api.jikan.moe/v4/*, caché Redis/memoria) ─
# JIKAN_UPSTREAM_ROOT=https://api.jikan.moe
# JIKAN_PROXY_MIN_GAP_MS=650
# JIKAN_CACHE_TTL_FULL_SEC=3600
# JIKAN_CACHE_TTL_LIST_SEC=900
# JIKAN_CACHE_TTL_DEFAULT_SEC=600

# ─── OAuth (opcional) ───────────────────────────────────────────────────────
BACKEND_URL=http://localhost:5001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── External APIs (opcional) ───────────────────────────────────────────────
# TMDB watch providers fallback (themoviedb.org → API Key v3)
TMDB_API_KEY=
# LibreTranslate self-hosted o público (ej. https://libretranslate.com)
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# ─── Web Push (VAPID, opcional) ───────────────────────────────────────────────
# Generar: npx web-push generate-vapid-keys
# VAPID_SUBJECT debe ser mailto:… o https://… (contacto del sitio).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:dev@localhost

# ─── Reviews: imágenes (Cloudinary, opcional) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Carpeta en Cloudinary (default: anirate/reviews)
CLOUDINARY_REVIEW_FOLDER=
